        {
          "name": "TC-CUST-004 — [MOCK ONLY] Service throws IllegalStateException → 500",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"firstName\": \"Bad\",\n    \"lastName\": \"Actor\",\n    \"email\": \"fraudster@evil.com\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{customerBaseUrl}}/api/v1/customers",
              "host": ["{{customerBaseUrl}}"],
              "path": ["api", "v1", "customers"]
            },
            "description": "⚠️ MOCK ONLY: This 500 scenario is only reproducible when FraudCheckService.isFraudulentCustomer() returns true. The real service always returns false. In isolation this request will return 200 OK.\n\nThe unit test verifies this via Mockito: doThrow(IllegalStateException).when(service).registerCustomer(any())."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// NOTE: Against the real service this returns 200 (FraudCheckService always returns false).",
                  "// This test case is only meaningful when CustomerService is mocked to throw.",
                  "pm.test('TC-CUST-004: [MOCK ONLY] Informational — real service returns 200', function () {",
                  "    pm.expect([200, 500]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
