    {
      "name": "Fraud Service",
      "description": "Endpoint: GET /api/v1/fraud-check/{customerId}\nReturns { \"isFraudster\": true|false } for a given customer ID.\n\nNote: The real FraudCheckService.isFraudulentCustomer() always returns false and saves a history record. TC-FRAUD-002 (isFraudster=true) is only achievable through service mocking.",
      "item": [
        {
          "name": "TC-FRAUD-001 — Legitimate customer → 200 + isFraudster=false",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{fraudBaseUrl}}/api/v1/fraud-check/1",
              "host": ["{{fraudBaseUrl}}"],
              "path": ["api", "v1", "fraud-check", "1"]
            },
            "description": "Valid integer customer ID. Expects 200 OK with JSON body { \"isFraudster\": false }."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-FRAUD-001: Status is 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('TC-FRAUD-001: Response is JSON', function () {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "pm.test('TC-FRAUD-001: isFraudster field is boolean false', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('isFraudster');",
                  "    pm.expect(body.isFraudster).to.be.a('boolean');",
                  "    pm.expect(body.isFraudster).to.eql(false);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "TC-FRAUD-002 — [MOCK ONLY] Fraudulent customer → 200 + isFraudster=true",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{fraudBaseUrl}}/api/v1/fraud-check/99",
              "host": ["{{fraudBaseUrl}}"],
              "path": ["api", "v1", "fraud-check", "99"]
            },
            "description": "⚠️ MOCK ONLY: The real FraudCheckService always returns false. isFraudster=true is only achievable when the service is mocked (Mockito). Against the real service this will return isFraudster=false."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-FRAUD-002: Status is 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('TC-FRAUD-002: isFraudster field exists and is boolean', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('isFraudster');",
                  "    pm.expect(body.isFraudster).to.be.a('boolean');",
                  "});",
                  "",
                  "// NOTE: Real service always returns false. True only via mock.",
                  "pm.test('TC-FRAUD-002: [Informational] isFraudster value noted', function () {",
                  "    const body = pm.response.json();",
                  "    console.log('isFraudster =', body.isFraudster, '(real service always returns false)');",
                  "    pm.expect(typeof body.isFraudster).to.eql('boolean');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "TC-FRAUD-003 — Large valid customer ID → 200 OK",
